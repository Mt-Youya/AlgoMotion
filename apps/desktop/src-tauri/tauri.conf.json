{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AlgoMotion",
  "version": "0.1.0",
  "identifier": "io.algomotion.desktop",
  "build": {
    "beforeDevCommand": "pnpm --filter @algomotion/web dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "pnpm --filter @algomotion/web build",
    "frontendDist": "../../web/out"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "AlgoMotion",
        "width": 1440,
        "height": 920,
        "minWidth": 960,
        "minHeight": 680,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Education",
    "shortDescription": "See algorithms move, one trace event at a time."
  }
}
