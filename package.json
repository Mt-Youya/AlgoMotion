{
  "name": "algomotion",
  "version": "0.1.0",
  "private": true,
  "description": "Cross-platform algorithm visualization and learning platform",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @algomotion/web dev",
    "build": "pnpm --filter @algomotion/web build",
    "start": "pnpm --filter @algomotion/web start",
    "web": "pnpm --filter @algomotion/web dev",
    "desktop": "pnpm --filter @algomotion/desktop tauri dev",
    "mobile:ios": "pnpm --filter @algomotion/mobile tauri ios dev",
    "mobile:android": "pnpm --filter @algomotion/mobile tauri android dev",
    "wasm": "pnpm --filter @algomotion/algo-wasm build",
    "remotion": "pnpm --filter @algomotion/videos studio",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "lint": "oxlint .",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check .",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "manim": "python3 -m manim -pqh tools/manim/scenes/master_theorem.py MasterTheorem",
    "clean": "rm -rf node_modules && rm -rf .turbo && rm -f pnpm-lock.yaml && pnpm -r --parallel exec rm -rf .turbo dist out .next tsconfig.tsbuildinfo node_modules",
    "clean:turbo": "rm -rf .turbo && pnpm -r rm -rf .turbo",
    "clean:rust": "pnpm --filter @algomotion/algo-wasm exec cargo clean && pnpm --filter @algomotion/desktop exec cargo clean --manifest-path src-tauri/Cargo.toml && pnpm --filter @algomotion/mobile exec cargo clean --manifest-path src-tauri/Cargo.toml",
    "clean:all": "pnpm clean && pnpm clean:rust"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "tsx": "^4.22.4",
    "turbo": "^2.9.18",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": "24"
  },
  "packageManager": "pnpm@11.6.0+sha512.9a36518224080c6fe5165afdcfe79bfa118c29be703f3f462b1e32efe1e98e47e8750b148e08286250aad4113cc7993ca413c4e2cd447752708c2ee5751bc95f"
}
